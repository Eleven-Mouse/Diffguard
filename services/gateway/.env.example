# =============================================================================
# DiffGuard Gateway - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Configuration ---
DIFFGUARD_API_KEY=
DIFFGUARD_API_KEY_ENV=DIFFGUARD_API_KEY
DIFFGUARD_PROVIDER=claude
DIFFGUARD_MODEL=claude-sonnet-4-20250514

# --- GitHub ---
DIFFGUARD_GITHUB_TOKEN=

# --- Webhook ---
DIFFGUARD_WEBHOOK_HMAC_SECRET=

# --- Tool Server ---
DIFFGUARD_TOOL_SECRET=

# --- Gateway Server ---
GATEWAY_WEBHOOK_PORT=8080
GATEWAY_TOOL_PORT=9090

# --- Agent Service ---
AGENT_HOST=localhost
AGENT_PORT=8000
