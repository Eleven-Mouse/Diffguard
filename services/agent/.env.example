# =============================================================================
# DiffGuard Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Configuration ---
DIFFGUARD_API_KEY=
DIFFGUARD_PROVIDER=claude
DIFFGUARD_MODEL=claude-sonnet-4-20250514
DIFFGUARD_LANGUAGE=zh

# --- GitHub (Action mode) ---
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_SHA=

# --- GitHub (Webhook mode) ---
DIFFGUARD_GITHUB_TOKEN=
DIFFGUARD_COMMENT_PR=true
DIFFGUARD_EXCLUDE_DIRS=

# --- Java Tool Server (optional) ---
JAVA_TOOL_SERVER_URL=
DIFFGUARD_TOOL_SECRET=

# --- Webhook HMAC (optional) ---
DIFFGUARD_WEBHOOK_HMAC_SECRET=

# --- Agent Server ---
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
LOG_LEVEL=info
